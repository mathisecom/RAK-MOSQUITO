{% comment %}
  Section : Hero Nutrition Moderne
  Responsive PC + Mobile
  Entièrement modifiable depuis l’éditeur Shopify
{% endcomment %}

<section
  id="HeroNutritionCloud-{{ section.id }}"
  class="hero-nutrition-cloud"
  {{ section.shopify_attributes }}
>
  <style>
    #HeroNutritionCloud-{{ section.id }} {
      --hnc-bg: {{ section.settings.background_color }};
      --hnc-card-bg: {{ section.settings.card_background }};
      --hnc-text: {{ section.settings.text_color }};
      --hnc-muted: {{ section.settings.muted_color }};
      --hnc-accent: {{ section.settings.accent_color }};
      --hnc-stars: {{ section.settings.stars_color }};
      --hnc-button-bg: {{ section.settings.button_background }};
      --hnc-button-text: {{ section.settings.button_text_color }};
      --hnc-radius: {{ section.settings.card_radius }}px;
      --hnc-container: {{ section.settings.container_width }}px;
      --hnc-gap: {{ section.settings.desktop_gap }}px;
      --hnc-heading-desktop: {{ section.settings.heading_size_desktop }}px;
      --hnc-heading-mobile: {{ section.settings.heading_size_mobile }}px;
      --hnc-body-size: {{ section.settings.body_size }}px;
      --hnc-rating-size: {{ section.settings.rating_size }}px;
      --hnc-image-ratio: {{ section.settings.image_ratio | times: 0.01 }} / 1;
      --hnc-card-shadow: 0 24px 70px rgba(0, 0, 0, {{ section.settings.card_shadow_opacity | times: 0.01 }});
      --hnc-button-shadow: 0 18px 35px rgba(0, 0, 0, {{ section.settings.button_shadow_opacity | times: 0.01 }});

      background: var(--hnc-bg);
      color: var(--hnc-text);
      padding-top: {{ section.settings.padding_top_desktop }}px;
      padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
      overflow: hidden;
    }

    #HeroNutritionCloud-{{ section.id }} * {
      box-sizing: border-box;
    }

    #HeroNutritionCloud-{{ section.id }} .hnc-container {
      width: min(100% - 40px, var(--hnc-container));
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: var(--hnc-gap);
    }

    #HeroNutritionCloud-{{ section.id }} .hnc-media {
      flex: 1 1 0;
      order: {% if section.settings.image_position_desktop == 'left' %}1{% else %}2{% endif %};
      min-width: 0;
    }

    #HeroNutritionCloud-{{ section.id }} .hnc-content {
      flex: 1 1 0;
      order: {% if section.settings.image_position_desktop == 'left' %}2{% else %}1{% endif %};
      max-width: {{ section.settings.content_width }}px;
      text-align: {{ section.settings.text_align_desktop }};
      min-width: 0;
    }

    #HeroNutritionCloud-{{ section.id }} .hnc-card {
      position: relative;
      width: 100%;
      aspect-ratio: var(--hnc-image-ratio);
      background: var(--hnc-card-bg);
      border-radius: var(--hnc-radius);
      overflow: hidden;
      box-shadow: var(--hnc-card-shadow);
      isolation: isolate;
    }

    #HeroNutritionCloud-{{ section.id }} .hnc-card::after {
      content: "";
      position: absolute;
      inset: 0;
      background:
        radial-gradient(circle at 20% 15%, rgba(255,255,255,0.45), transparent 34%),
        radial-gradient(circle at 75% 85%, rgba(255,255,255,0.22), transparent 28%);
      pointer-events: none;
      z-index: 2;
    }

    #HeroNutritionCloud-{{ section.id }} .hnc-image {
      width: 100%;
      height: 100%;
      display: block;
      object-fit: {{ section.settings.image_fit }};
      object-position: {{ section.settings.image_position }};
      position: relative;
      z-index: 1;
    }

    #HeroNutritionCloud-{{ section.id }} .hnc-placeholder {
      width: 100%;
      height: 100%;
      background: #f1f1ec;
    }

    #HeroNutritionCloud-{{ section.id }} .hnc-badge {
      position: absolute;
      z-index: 4;
      width: {{ section.settings.badge_size_desktop }}px;
      height: {{ section.settings.badge_size_desktop }}px;
      border-radius: 999px;
      background: {{ section.settings.badge_background }};
      color: {{ section.settings.badge_text_color }};
      border: {{ section.settings.badge_border_width }}px solid {{ section.settings.badge_border_color }};
      display: {% if section.settings.show_badge %}flex{% else %}none{% endif %};
      align-items: center;
      justify-content: center;
      flex-direction: column;
      line-height: 1;
      text-align: center;
      box-shadow: 0 12px 28px rgba(0,0,0,0.12);
    }

    #HeroNutritionCloud-{{ section.id }} .hnc-badge--top-left {
      top: {{ section.settings.badge_offset_y }}px;
      left: {{ section.settings.badge_offset_x }}px;
    }

    #HeroNutritionCloud-{{ section.id }} .hnc-badge--top-right {
      top: {{ section.settings.badge_offset_y }}px;
      right: {{ section.settings.badge_offset_x }}px;
    }

    #HeroNutritionCloud-{{ section.id }} .hnc-badge--bottom-left {
      bottom: {{ section.settings.badge_offset_y }}px;
      left: {{ section.settings.badge_offset_x }}px;
    }

    #HeroNutritionCloud-{{ section.id }} .hnc-badge--bottom-right {
      bottom: {{ section.settings.badge_offset_y }}px;
      right: {{ section.settings.badge_offset_x }}px;
    }

    #HeroNutritionCloud-{{ section.id }} .hnc-badge-main {
      font-size: {{ section.settings.badge_main_size }}px;
      font-weight: 800;
      letter-spacing: -0.04em;
    }

    #HeroNutritionCloud-{{ section.id }} .hnc-badge-sub {
      margin-top: 3px;
      font-size: {{ section.settings.badge_sub_size }}px;
      font-weight: 600;
    }

    #HeroNutritionCloud-{{ section.id }} .hnc-proof {
      display: flex;
      align-items: center;
      gap: 14px;
      margin-bottom: {{ section.settings.proof_margin_bottom }}px;

      {% if section.settings.text_align_desktop == 'center' %}
        justify-content: center;
      {% elsif section.settings.text_align_desktop == 'right' %}
        justify-content: flex-end;
      {% else %}
        justify-content: flex-start;
      {% endif %}
    }

    #HeroNutritionCloud-{{ section.id }} .hnc-avatars {
      display: flex;
      align-items: center;
      padding-left: 10px;
      flex-shrink: 0;
    }

    #HeroNutritionCloud-{{ section.id }} .hnc-avatar {
      width: {{ section.settings.avatar_size }}px;
      height: {{ section.settings.avatar_size }}px;
      border-radius: 999px;
      border: {{ section.settings.avatar_border_width }}px solid {{ section.settings.avatar_border_color }};
      overflow: hidden;
      margin-left: -10px;
      background: #ddd;
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }

    #HeroNutritionCloud-{{ section.id }} .hnc-avatar-img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    #HeroNutritionCloud-{{ section.id }} .hnc-avatar-fallback {
      font-size: 12px;
      font-weight: 700;
      color: #111;
      background: #eeeeee;
      width: 100%;
      height: 100%;
      display: grid;
      place-items: center;
    }

    #HeroNutritionCloud-{{ section.id }} .hnc-rating {
      line-height: 1.15;
      font-size: var(--hnc-rating-size);
      color: var(--hnc-text);
    }

    #HeroNutritionCloud-{{ section.id }} .hnc-stars {
      display: flex;
      gap: 1px;
      color: var(--hnc-stars);
      font-size: {{ section.settings.star_size }}px;
      line-height: 1;
      margin-bottom: 4px;
    }

    #HeroNutritionCloud-{{ section.id }} .hnc-rating-text {
      font-weight: 600;
    }

    #HeroNutritionCloud-{{ section.id }} .hnc-rating-text strong {
      font-weight: 900;
    }

    #HeroNutritionCloud-{{ section.id }} .hnc-heading {
      margin: 0;
      color: var(--hnc-text);
      font-family: {{ section.settings.heading_font_family }};
      font-size: clamp(var(--hnc-heading-mobile), 5vw, var(--hnc-heading-desktop));
      font-weight: {{ section.settings.heading_weight }};
      line-height: {{ section.settings.heading_line_height }};
      letter-spacing: -0.055em;
    }

    #HeroNutritionCloud-{{ section.id }} .hnc-heading-line {
      display: block;
    }

    #HeroNutritionCloud-{{ section.id }} .hnc-heading em {
      font-style: italic;
      font-weight: {{ section.settings.italic_weight }};
    }

    #HeroNutritionCloud-{{ section.id }} .hnc-brand-wrap {
      display: inline-flex;
      align-items: center;
      gap: 3px;
      white-space: nowrap;
    }

    #HeroNutritionCloud-{{ section.id }} .hnc-dot {
      width: 0.22em;
      height: 0.22em;
      background: var(--hnc-accent);
      border-radius: 999px;
      display: {% if section.settings.show_brand_dot %}inline-block{% else %}none{% endif %};
      transform: translateY(-0.18em);
    }

    #HeroNutritionCloud-{{ section.id }} .hnc-description {
      margin: {{ section.settings.description_margin_top }}px auto 0;
      color: var(--hnc-muted);
      font-size: var(--hnc-body-size);
      line-height: 1.45;
      max-width: {{ section.settings.description_width }}px;
    }

    #HeroNutritionCloud-{{ section.id }} .hnc-description p {
      margin: 0;
    }

    #HeroNutritionCloud-{{ section.id }} .hnc-description strong {
      color: var(--hnc-text);
      font-weight: 900;
    }

    #HeroNutritionCloud-{{ section.id }} .hnc-benefits {
      margin: {{ section.settings.benefits_margin_top }}px auto 0;
      display: {% if section.settings.show_benefits %}inline-flex{% else %}none{% endif %};
      align-items: center;
      justify-content: center;
      flex-wrap: wrap;
      gap: {{ section.settings.benefits_gap }}px;
      padding: {{ section.settings.benefits_padding_y }}px {{ section.settings.benefits_padding_x }}px;
      max-width: 100%;
      background: {{ section.settings.benefits_background }};
      color: {{ section.settings.benefits_text_color }};
      border: {{ section.settings.benefits_border_width }}px solid {{ section.settings.benefits_border_color }};
      border-radius: {{ section.settings.benefits_radius }}px;
      font-size: {{ section.settings.benefits_font_size }}px;
      font-weight: {{ section.settings.benefits_font_weight }};
      line-height: 1.2;
      letter-spacing: 0.04em;
    }

    #HeroNutritionCloud-{{ section.id }} .hnc-benefit {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      white-space: nowrap;
    }

    #HeroNutritionCloud-{{ section.id }} .hnc-benefit-icon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      color: {{ section.settings.benefits_icon_color }};
      font-size: {{ section.settings.benefits_icon_size }}px;
      line-height: 1;
      flex-shrink: 0;
    }

    #HeroNutritionCloud-{{ section.id }} .hnc-actions {
      margin-top: {{ section.settings.button_margin_top }}px;
      display: flex;
      flex-direction: column;
      align-items:
        {% if section.settings.text_align_desktop == 'center' %}center{% elsif section.settings.text_align_desktop == 'right' %}flex-end{% else %}flex-start{% endif %};
      gap: 12px;
    }

    #HeroNutritionCloud-{{ section.id }} .hnc-button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 12px;
      min-height: {{ section.settings.button_height }}px;
      padding: 0 {{ section.settings.button_padding_x }}px;
      border-radius: {{ section.settings.button_radius }}px;
      background: var(--hnc-button-bg);
      color: var(--hnc-button-text);
      font-size: {{ section.settings.button_font_size }}px;
      font-weight: 800;
      line-height: 1;
      text-decoration: none;
      box-shadow: var(--hnc-button-shadow);
      transition: transform 0.25s ease, box-shadow 0.25s ease, opacity 0.25s ease;
    }

    #HeroNutritionCloud-{{ section.id }} .hnc-button:hover {
      transform: translateY(-2px);
      opacity: 0.96;
    }

    #HeroNutritionCloud-{{ section.id }} .hnc-button-arrow {
      font-size: 1.2em;
      line-height: 1;
      transform: translateY(-1px);
    }

    #HeroNutritionCloud-{{ section.id }} .hnc-guarantee {
      display: {% if section.settings.show_guarantee %}inline-flex{% else %}none{% endif %};
      align-items: center;
      justify-content: center;
      gap: 6px;
      color: var(--hnc-muted);
      font-size: {{ section.settings.guarantee_size }}px;
      line-height: 1.25;
    }

    #HeroNutritionCloud-{{ section.id }} .hnc-guarantee-icon {
      font-size: 1.05em;
      color: var(--hnc-text);
    }

    {% if section.settings.enable_animation %}
      @media (prefers-reduced-motion: no-preference) {
        #HeroNutritionCloud-{{ section.id }} .hnc-card {
          animation: hncFloat-{{ section.id }} 5.5s ease-in-out infinite;
        }

        #HeroNutritionCloud-{{ section.id }} .hnc-badge {
          animation: hncBadge-{{ section.id }} 4.8s ease-in-out infinite;
        }

        @keyframes hncFloat-{{ section.id }} {
          0%, 100% {
            transform: translateY(0);
          }

          50% {
            transform: translateY(-6px);
          }
        }

        @keyframes hncBadge-{{ section.id }} {
          0%, 100% {
            transform: rotate(-2deg) scale(1);
          }

          50% {
            transform: rotate(2deg) scale(1.04);
          }
        }
      }
    {% endif %}

    @media screen and (max-width: 749px) {
      #HeroNutritionCloud-{{ section.id }} {
        padding-top: {{ section.settings.padding_top_mobile }}px;
        padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
      }

      #HeroNutritionCloud-{{ section.id }} .hnc-container {
        width: min(100% - 28px, var(--hnc-container));
        flex-direction: column;
        gap: {{ section.settings.mobile_gap }}px;
      }

      #HeroNutritionCloud-{{ section.id }} .hnc-media {
        width: 100%;
        order: {% if section.settings.image_position_mobile == 'top' %}1{% else %}2{% endif %};
      }

      #HeroNutritionCloud-{{ section.id }} .hnc-content {
        width: 100%;
        max-width: 100%;
        order: {% if section.settings.image_position_mobile == 'top' %}2{% else %}1{% endif %};
        text-align: {{ section.settings.text_align_mobile }};
      }

      #HeroNutritionCloud-{{ section.id }} .hnc-card {
        aspect-ratio: {{ section.settings.image_ratio_mobile | times: 0.01 }} / 1;
        border-radius: {{ section.settings.card_radius_mobile }}px;
      }

      #HeroNutritionCloud-{{ section.id }} .hnc-proof {
        margin-bottom: {{ section.settings.proof_margin_bottom_mobile }}px;

        {% if section.settings.text_align_mobile == 'center' %}
          justify-content: center;
        {% elsif section.settings.text_align_mobile == 'right' %}
          justify-content: flex-end;
        {% else %}
          justify-content: flex-start;
        {% endif %}
      }

      #HeroNutritionCloud-{{ section.id }} .hnc-heading {
        font-size: var(--hnc-heading-mobile);
        line-height: {{ section.settings.heading_line_height_mobile }};
      }

      #HeroNutritionCloud-{{ section.id }} .hnc-description {
        margin-top: {{ section.settings.description_margin_top_mobile }}px;
        font-size: {{ section.settings.body_size_mobile }}px;
      }

      #HeroNutritionCloud-{{ section.id }} .hnc-benefits {
        margin-top: {{ section.settings.benefits_margin_top_mobile }}px;
        width: {% if section.settings.benefits_full_mobile %}100%{% else %}auto{% endif %};
        font-size: {{ section.settings.benefits_font_size_mobile }}px;
        padding: {{ section.settings.benefits_padding_y_mobile }}px {{ section.settings.benefits_padding_x_mobile }}px;
        gap: {{ section.settings.benefits_gap_mobile }}px;
        {% if section.settings.benefits_stack_mobile %}
          flex-direction: column;
          align-items: center;
        {% endif %}
      }

      #HeroNutritionCloud-{{ section.id }} .hnc-benefit {
        white-space: {% if section.settings.benefits_stack_mobile %}normal{% else %}nowrap{% endif %};
        text-align: center;
      }

      #HeroNutritionCloud-{{ section.id }} .hnc-benefit-icon {
        font-size: {{ section.settings.benefits_icon_size_mobile }}px;
      }

      #HeroNutritionCloud-{{ section.id }} .hnc-actions {
        margin-top: {{ section.settings.button_margin_top_mobile }}px;
        align-items:
          {% if section.settings.text_align_mobile == 'center' %}center{% elsif section.settings.text_align_mobile == 'right' %}flex-end{% else %}flex-start{% endif %};
      }

      #HeroNutritionCloud-{{ section.id }} .hnc-button {
        width: {% if section.settings.button_full_mobile %}100%{% else %}auto{% endif %};
        min-height: {{ section.settings.button_height_mobile }}px;
        font-size: {{ section.settings.button_font_size_mobile }}px;
        padding: 0 {{ section.settings.button_padding_x_mobile }}px;
      }

      #HeroNutritionCloud-{{ section.id }} .hnc-badge {
        width: {{ section.settings.badge_size_mobile }}px;
        height: {{ section.settings.badge_size_mobile }}px;
      }

      #HeroNutritionCloud-{{ section.id }} .hnc-badge-main {
        font-size: {{ section.settings.badge_main_size_mobile }}px;
      }

      #HeroNutritionCloud-{{ section.id }} .hnc-badge-sub {
        font-size: {{ section.settings.badge_sub_size_mobile }}px;
      }
    }
  </style>

  <div class="hnc-container">
    <div class="hnc-media">
      <div class="hnc-card">
        {% if section.settings.main_image != blank %}
          {{
            section.settings.main_image
            | image_url: width: 1600
            | image_tag:
              loading: 'lazy',
              widths: '375, 550, 750, 990, 1200, 1600',
              sizes: '(min-width: 990px) 48vw, 92vw',
              class: 'hnc-image'
          }}
        {% else %}
          {{ 'product-1' | placeholder_svg_tag: 'hnc-placeholder' }}
        {% endif %}

        <div class="hnc-badge hnc-badge--{{ section.settings.badge_position }}">
          <span class="hnc-badge-main">{{ section.settings.badge_text_main | escape }}</span>
          <span class="hnc-badge-sub">{{ section.settings.badge_text_sub | escape }}</span>
        </div>
      </div>
    </div>

    <div class="hnc-content">
      {% assign avatar_blocks = section.blocks | where: 'type', 'avatar' %}
      {% assign benefit_blocks = section.blocks | where: 'type', 'benefit' %}

      {% if section.settings.show_social_proof %}
        <div class="hnc-proof">
          {% if section.settings.show_avatars %}
            <div class="hnc-avatars" aria-label="Clients satisfaits">
              {% if avatar_blocks.size > 0 %}
                {% for block in avatar_blocks %}
                  <span class="hnc-avatar" {{ block.shopify_attributes }}>
                    {% if block.settings.avatar_image != blank %}
                      {{
                        block.settings.avatar_image
                        | image_url: width: 120
                        | image_tag:
                          loading: 'lazy',
                          class: 'hnc-avatar-img',
                          alt: block.settings.avatar_alt
                      }}
                    {% else %}
                      <span class="hnc-avatar-fallback">{{ forloop.index }}</span>
                    {% endif %}
                  </span>
                {% endfor %}
              {% else %}
                {% for i in (1..3) %}
                  <span class="hnc-avatar">
                    <span class="hnc-avatar-fallback">{{ i }}</span>
                  </span>
                {% endfor %}
              {% endif %}
            </div>
          {% endif %}

          <div class="hnc-rating">
            {% if section.settings.show_stars and section.settings.star_count > 0 %}
              <div class="hnc-stars" aria-label="{{ section.settings.stars_label | escape }}">
                {% for i in (1..section.settings.star_count) %}
                  <span>{{ section.settings.star_symbol | escape }}</span>
                {% endfor %}
              </div>
            {% endif %}

            {% if section.settings.rating_text != blank %}
              <div class="hnc-rating-text">
                {{ section.settings.rating_text }}
              </div>
            {% endif %}
          </div>
        </div>
      {% endif %}

      <{{ section.settings.heading_tag }} class="hnc-heading">
        <span class="hnc-heading-line">
          {% if section.settings.heading_line_1 != blank %}
            <span>{{ section.settings.heading_line_1 | escape }}</span>
          {% endif %}

          {% if section.settings.heading_italic != blank %}
            <em>{{ section.settings.heading_italic | escape }}</em>
          {% endif %}
        </span>

        <span class="hnc-heading-line">
          {% if section.settings.brand_text != blank %}
            <span class="hnc-brand-wrap">
              <span>{{ section.settings.brand_text | escape }}</span>
              <span class="hnc-dot"></span>
            </span>
          {% endif %}

          {% if section.settings.heading_line_2 != blank %}
            <span>{{ section.settings.heading_line_2 | escape }}</span>
          {% endif %}
        </span>
      </{{ section.settings.heading_tag }}>

      {% if section.settings.description != blank %}
        <div class="hnc-description">
          {{ section.settings.description }}
        </div>
      {% endif %}

      {% if section.settings.show_benefits %}
        <div class="hnc-benefits" role="list" aria-label="Bénéfices produit">
          {% if benefit_blocks.size > 0 %}
            {% for block in benefit_blocks %}
              <div class="hnc-benefit" role="listitem" {{ block.shopify_attributes }}>
                {% if block.settings.benefit_icon != blank %}
                  <span class="hnc-benefit-icon">{{ block.settings.benefit_icon | escape }}</span>
                {% endif %}

                {% if block.settings.benefit_text != blank %}
                  <span>{{ block.settings.benefit_text | escape }}</span>
                {% endif %}
              </div>
            {% endfor %}
          {% else %}
            <div class="hnc-benefit" role="listitem">
              <span class="hnc-benefit-icon">✹</span>
              <span>100% Naturel</span>
            </div>

            <div class="hnc-benefit" role="listitem">
              <span class="hnc-benefit-icon">✹</span>
              <span>Élimine le duvet</span>
            </div>

            <div class="hnc-benefit" role="listitem">
              <span class="hnc-benefit-icon">✹</span>
              <span>Peau plus lisse</span>
            </div>
          {% endif %}
        </div>
      {% endif %}

      <div class="hnc-actions">
        {% if section.settings.button_text != blank %}
          <a class="hnc-button" href="{{ section.settings.button_link | default: '#' }}">
            <span>{{ section.settings.button_text | escape }}</span>

            {% if section.settings.button_arrow != blank %}
              <span class="hnc-button-arrow">{{ section.settings.button_arrow | escape }}</span>
            {% endif %}
          </a>
        {% endif %}

        {% if section.settings.guarantee_text != blank %}
          <div class="hnc-guarantee">
            {% if section.settings.guarantee_icon != blank %}
              <span class="hnc-guarantee-icon">{{ section.settings.guarantee_icon | escape }}</span>
            {% endif %}

            <span>{{ section.settings.guarantee_text | escape }}</span>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero nutrition moderne",
  "tag": "section",
  "class": "section-hero-nutrition-cloud",
  "settings": [
    {
      "type": "header",
      "content": "Image principale"
    },
    {
      "type": "image_picker",
      "id": "main_image",
      "label": "Image produit principale"
    },
    {
      "type": "select",
