{% comment %}
  Barre d'annonce custom - Shopify Section
{% endcomment %}

<section id="announcement-bar-{{ section.id }}" class="custom-announcement-bar">
  {% if section.settings.link != blank %}
    <a href="{{ section.settings.link }}" class="custom-announcement-bar__inner">
  {% else %}
    <div class="custom-announcement-bar__inner">
  {% endif %}

    <div class="custom-announcement-bar__content">
      {% if section.settings.show_icon %}
        <span class="custom-announcement-bar__icon">
          {% if section.settings.icon_image != blank %}
            <img
              src="{{ section.settings.icon_image | image_url: width: 80 }}"
              alt=""
              loading="lazy"
            >
          {% else %}
            {% case section.settings.icon_type %}
              {% when 'fire' %}
                🔥
              {% when 'bolt' %}
                ⚡
              {% when 'star' %}
                ★
              {% when 'gift' %}
                🎁
              {% when 'tag' %}
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M20 13.5 13.5 20 4 10.5V4h6.5L20 13.5Z"></path>
                  <circle cx="8" cy="8" r="1.5"></circle>
                </svg>
              {% when 'percent' %}
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M19 5 5 19"></path>
                  <circle cx="7.5" cy="7.5" r="2.5"></circle>
                  <circle cx="16.5" cy="16.5" r="2.5"></circle>
                </svg>
              {% when 'megaphone' %}
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M4 13h3l9 5V6l-9 5H4v2Z"></path>
                  <path d="M7 13v5"></path>
                  <path d="M18 10c1 .8 1.5 1.8 1.5 3S19 15.2 18 16"></path>
                </svg>
            {% endcase %}
          {% endif %}
        </span>
      {% endif %}

      {% if section.settings.main_text != blank %}
        <span class="custom-announcement-bar__text">
          {{ section.settings.main_text }}
        </span>
      {% endif %}

      {% if section.settings.badge_text != blank %}
        <span class="custom-announcement-bar__badge">
          {{ section.settings.badge_text }}
        </span>
      {% endif %}
    </div>

  {% if section.settings.link != blank %}
    </a>
  {% else %}
    </div>
  {% endif %}
</section>

<style>
  #announcement-bar-{{ section.id }} {
    width: 100%;
    background: {{ section.settings.background_color }};
    border-top: {{ section.settings.border_top_width }}px solid {{ section.settings.border_color }};
    border-bottom: {{ section.settings.border_bottom_width }}px solid {{ section.settings.border_color }};
    overflow: hidden;
  }

  #announcement-bar-{{ section.id }} .custom-announcement-bar__inner {
    min-height: {{ section.settings.bar_height }}px;
    padding: {{ section.settings.padding_vertical }}px {{ section.settings.padding_horizontal }}px;
    display: flex;
    align-items: center;
    justify-content: {{ section.settings.content_position }};
    text-decoration: none;
    color: inherit;
  }

  #announcement-bar-{{ section.id }} .custom-announcement-bar__content {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: {{ section.settings.elements_gap }}px;
    flex-wrap: {{ section.settings.wrap_content }};
    text-align: center;
  }

  #announcement-bar-{{ section.id }} .custom-announcement-bar__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: {{ section.settings.icon_box_size }}px;
    height: {{ section.settings.icon_box_size }}px;
    color: {{ section.settings.icon_color }};
    font-size: {{ section.settings.icon_size }}px;
    line-height: 1;
    flex: 0 0 auto;
  }

  #announcement-bar-{{ section.id }} .custom-announcement-bar__icon svg {
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
    fill: none;
    stroke: currentColor;
    stroke-width: {{ section.settings.icon_stroke_width }};
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  #announcement-bar-{{ section.id }} .custom-announcement-bar__icon img {
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
    object-fit: contain;
    display: block;
  }

  #announcement-bar-{{ section.id }} .custom-announcement-bar__text {
    color: {{ section.settings.text_color }};
    font-size: {{ section.settings.text_size_mobile }}px;
    font-weight: {{ section.settings.text_weight }};
    letter-spacing: {{ section.settings.text_letter_spacing }}px;
    text-transform: {{ section.settings.text_transform }};
    line-height: {{ section.settings.text_line_height }}%;
    white-space: nowrap;
  }

  #announcement-bar-{{ section.id }} .custom-announcement-bar__badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: {{ section.settings.badge_height }}px;
    padding: 0 {{ section.settings.badge_padding_horizontal }}px;
    background: {{ section.settings.badge_background_color }};
    color: {{ section.settings.badge_text_color }};
    border: {{ section.settings.badge_border_width }}px solid {{ section.settings.badge_border_color }};
    border-radius: {{ section.settings.badge_radius }}px;
    font-size: {{ section.settings.badge_text_size_mobile }}px;
    font-weight: {{ section.settings.badge_text_weight }};
    letter-spacing: {{ section.settings.badge_letter_spacing }}px;
    text-transform: {{ section.settings.badge_text_transform }};
    line-height: {{ section.settings.badge_line_height }}%;
    white-space: nowrap;
  }

  @media screen and (min-width: 750px) {
    #announcement-bar-{{ section.id }} .custom-announcement-bar__text {
      font-size: {{ section.settings.text_size_desktop }}px;
    }

    #announcement-bar-{{ section.id }} .custom-announcement-bar__badge {
      font-size: {{ section.settings.badge_text_size_desktop }}px;
    }
  }
</style>

{% schema %}
{
  "name": "Barre annonce custom",
  "settings": [
    {
      "type": "header",
      "content": "Contenu"
    },
    {
      "type": "text",
      "id": "main_text",
      "label": "Texte principal",
      "default": "SITEWIDE SALE"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Texte du badge",
      "default": "UP TO 50% OFF"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Lien de la barre"
    },
    {
      "type": "header",
      "content": "Icône"
    },
    {
      "type": "checkbox",
      "id": "show_icon",
      "label": "Afficher une icône",
      "default": true
    },
    {
      "type": "select",
      "id": "icon_type",
      "label": "Type d’icône",
      "default": "fire",
      "options": [
        {
          "value": "fire",
          "label": "Feu"
        },
        {
          "value": "bolt",
          "label": "Éclair"
        },
        {
          "value": "star",
          "label": "Étoile"
        },
        {
          "value": "gift",
          "label": "Cadeau"
        },
        {
          "value": "tag",
          "label": "Étiquette"
        },
        {
          "value": "percent",
          "label": "Pourcentage"
        },
        {
          "value": "megaphone",
          "label": "Annonce"
        }
      ]
    },
    {
      "type": "image_picker",
      "id": "icon_image",
      "label": "Icône personnalisée",
      "info": "Si tu ajoutes une image ici, elle remplacera l’icône sélectionnée."
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Taille de l’icône",
      "min": 10,
      "max": 36,
      "step": 1,
      "default": 16
    },
    {
      "type": "range",
      "id": "icon_box_size",
      "label": "Zone de l’icône",
      "min": 10,
      "max": 44,
      "step": 1,
      "default": 18
    },
    {
      "type": "range",
      "id": "icon_stroke_width",
      "label": "Épaisseur icône SVG",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 2
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Couleur de l’icône",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Couleurs"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Fond de la barre",
      "default": "#11233f"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Couleur texte principal",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "badge_background_color",
      "label": "Fond du badge",
      "default": "#4f86e8"
    },
    {
      "type": "color",
      "id": "badge_text_color",
      "label": "Couleur texte badge",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "badge_border_color",
      "label": "Couleur bordure badge",
      "default": "#4f86e8"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Couleur bordures barre",
      "default": "#11233f"
    },
    {
      "type": "header",
      "content": "Dimensions barre"
    },
    {
      "type": "range",
      "id": "bar_height",
      "label": "Hauteur minimale",
      "min": 24,
      "max": 90,
      "step": 1,
      "default": 52
    },
    {
      "type": "range",
      "id": "padding_vertical",
      "label": "Marge intérieure haut/bas",
      "min": 0,
      "max": 30,
      "step": 1,
      "default": 8
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Marge intérieure côtés",
      "min": 0,
      "max": 60,
      "step": 1,
      "default": 12
    },
    {
      "type": "range",
      "id": "elements_gap",
      "label": "Espace entre les éléments",
      "min": 2,
      "max": 40,
      "step": 1,
      "default": 12
    },
    {
      "type": "select",
      "id": "content_position",
      "label": "Position du contenu",
      "default": "center",
      "options": [
        {
          "value": "flex-start",
          "label": "Gauche"
        },
        {
          "value": "center",
          "label": "Centre"
        },
        {
          "value": "flex-end",
          "label": "Droite"
        }
      ]
    },
    {
      "type": "select",
      "id": "wrap_content",
      "label": "Retour à la ligne sur petit écran",
      "default": "nowrap",
      "options": [
        {
          "value": "nowrap",
          "label": "Non"
        },
        {
          "value": "wrap",
          "label": "Oui"
        }
      ]
    },
    {
      "type": "range",
      "id": "border_top_width",
      "label": "Épaisseur bordure haute",
      "min": 0,
      "max": 8,
      "step": 1,
      "default": 0
    },
    {
      "type": "range",
      "id": "border_bottom_width",
      "label": "Épaisseur bordure basse",
      "min": 0,
      "max": 8,
      "step": 1,
      "default": 0
    },
    {
      "type": "header",
      "content": "Texte principal"
    },
    {
      "type": "range",
      "id": "text_size_mobile",
      "label": "Taille texte mobile",
      "min": 8,
      "max": 28,
      "step": 1,
      "default": 14
    },
    {
      "type": "range",
      "id": "text_size_desktop",
      "label": "Taille texte desktop",
      "min": 8,
      "max": 34,
      "step": 1,
      "default": 15
    },
    {
      "type": "range",
      "id": "text_weight",
      "label": "Graisse texte",
      "min": 300,
      "max": 900,
      "step": 100,
      "default": 800
    },
    {
      "type": "range",
      "id": "text_letter_spacing",
      "label": "Espacement lettres texte",
      "min": -2,
      "max": 5,
      "step": 1,
      "default": 0
    },
    {
      "type": "range",
      "id": "text_line_height",
      "label": "Interligne texte",
      "min": 80,
      "max": 200,
      "step": 5,
      "default": 100
    },
    {
      "type": "select",
      "id": "text_transform",
      "label": "Transformation texte",
      "default": "uppercase",
      "options": [
        {
          "value": "none",
          "label": "Normal"
        },
        {
          "value": "uppercase",
          "label": "Majuscules"
        },
        {
          "value": "lowercase",
          "label": "Minuscules"
        },
        {
          "value": "capitalize",
          "label": "Première lettre majuscule"
        }
      ]
    },
    {
      "type": "header",
      "content": "Badge / pastille"
    },
    {
      "type": "range",
      "id": "badge_height",
      "label": "Hauteur badge",
      "min": 20,
      "max": 60,
      "step": 1,
      "default": 30
    },
    {
      "type": "range",
      "id": "badge_padding_horizontal",
      "label": "Marge intérieure badge côtés",
      "min": 6,
      "max": 40,
      "step": 1,
      "default": 17
    },
    {
      "type": "range",
      "id": "badge_radius",
      "label": "Arrondi badge",
      "min": 0,
      "max": 40,
      "step": 1,
      "default": 8
    },
    {
      "type": "range",
      "id": "badge_border_width",
      "label": "Épaisseur bordure badge",
      "min": 0,
      "max": 6,
      "step": 1,
      "default": 0
    },
    {
      "type": "range",
      "id": "badge_text_size_mobile",
      "label": "Taille texte badge mobile",
      "min": 8,
      "max": 28,
      "step": 1,
      "default": 14
    },
    {
      "type": "range",
      "id": "badge_text_size_desktop",
      "label": "Taille texte badge desktop",
      "min": 8,
      "max": 34,
      "step": 1,
      "default": 15
    },
    {
      "type": "range",
      "id": "badge_text_weight",
      "label": "Graisse texte badge",
      "min": 300,
      "max": 900,
      "step": 100,
      "default": 800
    },
    {
      "type": "range",
      "id": "badge_letter_spacing",
      "label": "Espacement lettres badge",
      "min": -2,
      "max": 5,
      "step": 1,
      "default": 0
    },
    {
      "type": "range",
      "id": "badge_line_height",
      "label": "Interligne badge",
      "min": 80,
      "max": 200,
      "step": 5,
      "default": 100
    },
    {
      "type": "select",
      "id": "badge_text_transform",
      "label": "Transformation badge",
      "default": "uppercase",
      "options": [
        {
          "value": "none",
          "label": "Normal"
        },
        {
          "value": "uppercase",
          "label": "Majuscules"
        },
        {
          "value": "lowercase",
          "label": "Minuscules"
        },
        {
          "value": "capitalize",
          "label": "Première lettre majuscule"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Barre annonce custom"
    }
  ]
}
{% endschema %}